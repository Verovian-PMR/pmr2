# ===== VivIPractice Environment Variables =====
# Copy this file to .env and fill in values. NEVER commit .env files.

# --- Database (Data Plane - Per Tenant) ---
DATABASE_URL="postgresql://vivipractice:changeme@localhost:5432/vivipractice_dev?schema=public"

# --- Database (Control Plane - Vendor Only) ---
CONTROL_PLANE_DATABASE_URL="postgresql://vivipractice:changeme@localhost:5432/vivipractice_control?schema=public"

# --- Auth / JWT ---
JWT_SECRET="CHANGE_ME_TO_A_SECURE_RANDOM_STRING"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# --- MFA ---
MFA_ISSUER="VivIPractice"

# --- S3-Compatible Storage ---
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="vivipractice-media"
S3_REGION="us-east-1"

# --- Email (SMTP) ---
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@vivipractice.com"

# --- App URLs ---
API_URL="http://localhost:3001"
DASHBOARD_URL="http://localhost:3002"
PUBLIC_SITE_URL="http://localhost:3003"
CONTROL_HUB_URL="http://localhost:3004"

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Encryption ---
ENCRYPTION_KEY="CHANGE_ME_32_BYTE_HEX_KEY"

# --- Node Environment ---
NODE_ENV="development"
